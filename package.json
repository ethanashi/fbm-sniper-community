{
  "name": "fbm-sniper-community",
  "version": "2.0.1",
  "description": "Open-source multi-platform marketplace sniper with Cars, Facebook, Wallapop, and Vinted bots.",
  "type": "module",
  "main": "electron.cjs",
  "license": "MIT",
  "scripts": {
    "seed": "node lib/seed-sample-data.js",
    "scan": "node lib/scanner.js",
    "scan:test": "node lib/scanner.js --test",
    "ui": "node server.cjs",
    "desktop": "electron electron.cjs",
    "check": "node --check lib/scanner.js && node --check lib/fb-scraper.js && node --check lib/fb-session.js && node --check lib/facebook-sniper.js && node --check lib/wallapop-sniper.js && node --check lib/vinted-sniper.js && node --check lib/shared-marketplace/notifier.js && node --check server.cjs && node --check electron.cjs && node --check ui/app.js",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:win:local": "node build/build-win-local.cjs",
    "build:all": "npm run build:mac && npm run build:win:local"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "chalk": "^5.3.0",
    "dayjs": "^1.11.10",
    "express": "^4.22.1",
    "puppeteer": "^24.40.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^25.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "build": {
    "appId": "com.fbmsniper.community",
    "productName": "FBM Sniper Community",
    "copyright": "MIT",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "electron.cjs",
      "server.cjs",
      "lib/**/*",
      "ui/**/*",
      "config/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/puppeteer/puppeteer-cache/**/*",
      "!**/*.map",
      "!**/test/**/*",
      "!**/tests/**/*",
      "!**/spec/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.png",
      "identity": null,
      "gatekeeperAssess": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "afterPack": "build/after-pack.cjs",
    "dmg": {
      "title": "FBM Sniper Community",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
