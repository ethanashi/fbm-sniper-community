# Reference environment variables for local CLI runs and packaging.
# The app does not auto-load this file; export the values you need in your shell.

# Optional manual Vinted auth cookie. Paste the cookie string that includes
# access_token_web=... if the auto-refresh flow is not enough for your setup.
VINTED_COOKIE=

# Optional dedicated proxy for the Vinted sniper.
VINTED_PROXY=

# Optional legacy Facebook proxy env vars. The shared marketplace UI can also
# derive these from the configured proxy URL.
PROXY_ENABLED=false
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=
